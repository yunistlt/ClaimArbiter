TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (опционально): если не заданы, бот работает на локальных хранилищах.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_DB_PASSWORD=your_db_password_if_needed

# Telegram ID пользователей, которым всегда разрешён доступ в личку.
# Узнать свой ID можно у @userinfobot.
# ВАЖНО: без этой строки доступ в ЛС сбрасывается при каждом рестарте контейнера!
ALLOWED_USER_IDS=682234108

# Автоматически добавлять пользователя в allowlist при первом сообщении в личке.
# Рекомендуется для внутреннего корпоративного использования.
AUTO_ALLOW_PRIVATE_USERS=1

# Telegram ID пользователей, которые могут проверять/согласовывать документы.
# Если не задано — используется ALLOWED_USER_IDS.
# LAWYER_REVIEWER_IDS=682234108

# --- Веб-панель администратора ---
# Порт, на котором доступна веб-панель (по умолчанию 8080)
# WEB_PORT=8080

# Логин и пароль для входа в веб-панель (HTTP Basic Auth)
# ВАЖНО: обязательно смените пароль перед деплоем!
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=changeme
